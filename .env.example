# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080

# ── Encryption ────────────────────────────────────────────────────────────────
# Run: python crypto.py encrypt
# to generate these values.
# Master password is entered manually on startup.
ANTHROPIC_API_KEY_ENCRYPTED=
CRYPTO_SALT=

# ── Access control ────────────────────────────────────────────────────────────
# Comma-separated list of allowed IPs
ALLOWED_IPS=127.0.0.1

# ── Allowed models ────────────────────────────────────────────────────────────
ALLOWED_MODELS=claude-sonnet-4-6,claude-sonnet-4-20250514,claude-haiku-4-5-20251001,claude-sonnet-4-5

# ── Daily spend limit (USD) ───────────────────────────────────────────────────
DAILY_LIMIT=10.0

# ── Pseudo keys (one per project) ────────────────────────────────────────────
# Generate random values, e.g.: python -c "import secrets; print('sk-proxy-golf-' + secrets.token_hex(16))"
PSEUDO_KEY_GOLF=sk-proxy-golf-
PSEUDO_KEY_TEAMS=sk-proxy-teams-
PSEUDO_KEY_PRICEBOOST=sk-proxy-boost-

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=/opt/claude-proxy/usage.db
